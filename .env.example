# Base de datos — Postgres (Neon). En Vercel, la integración de Neon inyecta
# estas variables automáticamente al conectar la base al proyecto. Para correr
# localmente, pegá las cadenas que muestra Neon en su snippet ".env.local".
#   POSTGRES_PRISMA_URL   = pooled (pgbouncer) — la usa la app en runtime
#   DATABASE_URL_UNPOOLED = directo (sin pooler) — migraciones / db push
POSTGRES_PRISMA_URL="postgresql://user:pass@host-pooler.neon.tech/db?sslmode=require&pgbouncer=true&connect_timeout=15"
DATABASE_URL_UNPOOLED="postgresql://user:pass@host.neon.tech/db?sslmode=require"

# Secreto para firmar las sesiones (JWT). Generar uno propio con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET="cambiame-por-un-secreto-largo-y-aleatorio"

# Cuenta de administrador (única que puede entrar). El build de Vercel corre el
# seed con estas variables; la clave es la fuente de verdad en ADMIN_PASSWORD.
ADMIN_EMAIL="contacto@patagoniasimracing.cl"
ADMIN_PASSWORD="elegí-una-clave-fuerte"
ADMIN_NAME="Patricio"
