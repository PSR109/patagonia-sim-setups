# Base de datos — Postgres (Neon en producción). En Vercel, la integración de
# Neon inyecta estas variables; localmente, pegá la connection string de Neon.
#   DATABASE_URL = string POOLED (con ?pgbouncer=true) — la usa la app en runtime
#   DIRECT_URL   = string DIRECTO (sin pooler) — la usan migraciones / db push
DATABASE_URL="postgresql://user:pass@host-pooler.neon.tech/db?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:pass@host.neon.tech/db?sslmode=require"

# Secreto para firmar las sesiones (JWT). Generar uno propio con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET="cambiame-por-un-secreto-largo-y-aleatorio"
