# Base de datos. SQLite por defecto (archivo local). Para producir en la nube,
# cambiar a Postgres: DATABASE_URL="postgresql://user:pass@host:5432/db"
DATABASE_URL="file:./dev.db"

# Secreto para firmar las sesiones (JWT). Generar uno propio con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET="cambiame-por-un-secreto-largo-y-aleatorio"
